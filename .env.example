# ── Aplicación ────────────────────────────
APP_ENV=development
PORT=8080
STORE_NAME="Mi Tienda"
LOG_LEVEL=debug

# ── Base de Datos (UN solo pool, sin magia) ─
DATABASE_URL=postgres://shopuser:shoppass@localhost:5432/shopgo?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# ── Redis ──────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── JWT (RSA asimétrico) ───────────────────
JWT_PRIVATE_KEY_PATH=./deploy/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./deploy/secrets/jwt_public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Stripe (directo, sin Connect) ──────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Storage ────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=shopgo
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Notificaciones ─────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=no-reply@tutienda.com
STORE_ADMIN_EMAIL=admin@tutienda.com

# ── CORS ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
ADMIN_IPS=

# ── Negocio ────────────────────────────────
DEFAULT_TAX_RATE=0.16
DEFAULT_CURRENCY=MXN
